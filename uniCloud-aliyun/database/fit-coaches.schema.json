{
  "bsonType": "object",
  "required": ["uid", "name", "tags"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": "doc.uid == auth.uid",
    "delete": "doc.uid == auth.uid"
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "uid": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "name": {
      "bsonType": "string",
      "description": "教练姓名"
    },
    "avatar": {
      "bsonType": "string",
      "description": "头像URL"
    },
    "title": {
      "bsonType": "string",
      "description": "头衔/认证"
    },
    "score": {
      "bsonType": "double",
      "description": "评分"
    },
    "tags": {
      "bsonType": "array",
      "description": "标签",
      "items": {
        "bsonType": "string"
      }
    },
    "desc": {
      "bsonType": "string",
      "description": "简介"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}