{
  "bsonType": "object",
  "required": ["user_id", "coach_id", "project"],
  "permission": {
    "read": "doc.user_id == auth.uid || doc.coach_id == auth.uid",
    "create": "auth.uid != null",
    "update": "doc.user_id == auth.uid || doc.coach_id == auth.uid",
    "delete": "false"
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "预约用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "coach_id": {
      "bsonType": "string",
      "description": "被预约教练ID"
    },
    "coach_name": {
      "bsonType": "string",
      "description": "教练名称快照"
    },
    "project": {
      "bsonType": "string",
      "description": "预约项目/标签"
    },
    "note": {
      "bsonType": "string",
      "description": "备注"
    },
    "status": {
      "bsonType": "int",
      "description": "状态: 0-待确认, 1-已确认, 2-已拒绝, 3-已完成",
      "defaultValue": 0
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}