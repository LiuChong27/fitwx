{
  "bsonType": "object",
  "required": ["feed_id", "user_id"],
  "permission": {
    "read": true,
    "create": "auth.uid != null",
    "update": false,
    "delete": "doc.user_id == auth.uid"
  },
  "properties": {
    "_id": {
      "description": "点赞记录ID"
    },
    "feed_id": {
      "bsonType": "string",
      "description": "动态ID",
      "foreignKey": "fit-feeds._id"
    },
    "user_id": {
      "bsonType": "string",
      "description": "点赞用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "点赞时间",
      "defaultValue": {
        "$env": "now"
      }
    }
  },
  "indexes": [
    {
      "name": "idx_user_id_feed_id",
      "keyPath": {
        "user_id": 1,
        "feed_id": 1
      }
    }
  ]
}
