{
  "bsonType": "object",
  "required": ["conversation_id", "sender_id", "content"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "conversation_id": {
      "bsonType": "string",
      "description": "会话ID",
      "foreignKey": "fit-conversations._id"
    },
    "sender_id": {
      "bsonType": "string",
      "description": "发送者用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "content": {
      "bsonType": "string",
      "description": "消息内容",
      "maxLength": 2000
    },
    "type": {
      "bsonType": "string",
      "description": "消息类型",
      "enum": ["text", "image", "system"],
      "defaultValue": "text"
    },
    "read": {
      "bsonType": "bool",
      "description": "是否已读",
      "defaultValue": false
    },
    "create_date": {
      "bsonType": "number",
      "description": "创建时间（毫秒时间戳）"
    }
  },
  "indexes": [
    {
      "name": "idx_conversation_date",
      "keyPath": {
        "conversation_id": 1,
        "create_date": -1
      }
    },
    {
      "name": "idx_conversation_read_sender",
      "keyPath": {
        "conversation_id": 1,
        "read": 1,
        "sender_id": 1
      }
    }
  ]
}
