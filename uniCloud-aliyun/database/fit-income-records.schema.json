{
  "bsonType": "object",
  "required": ["uid", "amount", "title"],
  "permission": {
    "read": "doc.uid == auth.uid",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "uid": {
      "bsonType": "string",
      "description": "教练用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "booking_id": {
      "bsonType": "string",
      "description": "关联的预约ID"
    },
    "student_id": {
      "bsonType": "string",
      "description": "学员用户ID"
    },
    "title": {
      "bsonType": "string",
      "description": "收入项目标题",
      "maxLength": 100
    },
    "amount": {
      "bsonType": "int",
      "description": "金额(分)",
      "minimum": 0
    },
    "type": {
      "bsonType": "string",
      "description": "收入类型",
      "enum": ["private_course", "group_course", "camp", "gift", "other"],
      "defaultValue": "private_course"
    },
    "status": {
      "bsonType": "int",
      "description": "状态: 0=待结算, 1=已结算, 2=已退款",
      "defaultValue": 0
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
