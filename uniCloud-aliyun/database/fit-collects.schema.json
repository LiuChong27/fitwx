{
  "bsonType": "object",
  "required": ["feed_id", "user_id"],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": "auth.uid != null",
    "update": false,
    "delete": "doc.user_id == auth.uid"
  },
  "properties": {
    "_id": {
      "description": "收藏记录ID"
    },
    "feed_id": {
      "bsonType": "string",
      "description": "动态ID",
      "foreignKey": "fit-feeds._id"
    },
    "user_id": {
      "bsonType": "string",
      "description": "收藏用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "收藏时间",
      "defaultValue": {
        "$env": "now"
      }
    }
  }
}
